PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas connection string. For local development you can use local MongoDB.
MONGODB_URI=mongodb://127.0.0.1:27017/appify
MONGODB_DB_NAME=appify

# Cloudinary uploads. Required in production.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=appify

# Optional Google OAuth.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
